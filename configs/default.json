{
  "source_root": "${MUSE_SOURCE_ROOT:-data/source}",
  "workspace_root": ".",
  "drawcad_root": "${DRAWCAD_ROOT:-external/DrawCAD}",
  "drawcad_runner": "${DRAWCAD_RUNNER:-external/drawcad_runner.py}",
  "validator_root": "${VALIDATOR_ROOT:-external/validator}",
  "python_executable": "${MUSE_PYTHON:-python3}",
  "selected_tasks": ["table", "stool", "wave_vase"],
  "models": [
    {
      "label": "gpt-4o",
      "provider": "openai",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
